# Environment variables for Offline Translator
# Copy this file to .env and fill in your API keys

# OpenAI API key (for cloud STT fallback and TTS)
OPENAI_API_KEY=sk-...

# Claude API key (for translation refinement)
CLAUDE_API_KEY=sk-ant-...

# Optional: Custom model cache directory
# HF_HOME=/path/to/huggingface/cache
